---
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import Gallery from "../components/Gallery.astro";
import Footer from "../components/Footer.astro";
---
<Base title="Realisaties" description="Een selectie van tegel- en vloerprojecten door Merati Tegelwerken.">
  <Header />
  <main id="main">
    <section class="page-hero">
      <div class="container">
        <span class="eyebrow eyebrow-light" data-anim="reveal">Realisaties</span>
        <h1 class="display" data-hero-title>Ons werk spreekt <em>voor zich.</em></h1>
        <p class="section-lead" data-anim="reveal">
          Een selectie van tegel- en vloerprojecten: badkamers, keukens, laminaat en
          parket, en buitenruimten.
        </p>
      </div>
    </section>
    <Gallery />
  </main>
  <Footer />
</Base>
