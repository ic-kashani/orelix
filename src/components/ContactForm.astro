<form class="contact-form" data-contact-form novalidate>
  <input
    type="text"
    name="website"
    class="hp-field"
    tabindex="-1"
    autocomplete="off"
    aria-hidden="true"
  />

  <div class="field">
    <label for="name">Naam</label>
    <input id="name" name="name" type="text" autocomplete="name" required />
  </div>
  <div class="field">
    <label for="email">E-mail</label>
    <input id="email" name="email" type="email" autocomplete="email" required />
  </div>
  <div class="field">
    <label for="phone">Telefoon</label>
    <input id="phone" name="phone" type="tel" autocomplete="tel" placeholder="+32 ..." />
  </div>
  <div class="field">
    <label for="company">Bedrijf</label>
    <input id="company" name="company" type="text" autocomplete="organization" />
  </div>
  <div class="field">
    <label for="interest">Waar wilt u tijd besparen?</label>
    <select id="interest" name="interest">
      <option value="">Kies een onderwerp</option>
      <option>E-mails en klantvragen</option>
      <option>Offertes en opvolging</option>
      <option>Planning en afspraken</option>
      <option>Administratie en documenten</option>
      <option>Rapportering</option>
      <option>Nog niet zeker</option>
    </select>
  </div>
  <div class="field field-full">
    <label for="message">Vertel kort waar uw team tijd verliest</label>
    <textarea id="message" name="message" rows="5" required></textarea>
  </div>
  <button type="submit" class="btn btn-primary btn-lg">Plan een gratis analyse</button>
  <p class="form-error" hidden role="alert"></p>
  <p class="form-note">Uw bericht komt rechtstreeks in onze inbox. Lees hoe we uw gegevens behandelen in ons <a href="/privacy">privacybeleid</a>.</p>
</form>
