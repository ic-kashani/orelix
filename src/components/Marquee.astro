---
const words = [
  "AI Receptionist",
  "AI Sales",
  "Office Assistant",
  "Customer Support",
  "Workflow Automation",
  "Digital Workforce",
  "24/7 Operations",
  "CRM Integration",
];
const loop = [...words, ...words];
---
<div class="marquee" aria-hidden="true">
  <div class="marquee-track">
    {loop.map((w) => <span>{w}</span>)}
  </div>
</div>
