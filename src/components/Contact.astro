---
import settings from "../content/settings.json";
import ContactForm from "./ContactForm.astro";
const c = settings.contact;
const phoneHref = c.phone?.replace(/\s+/g, "") ?? "";
---
<section id="contact" class="section contact">
  <div class="container">
    <header class="section-head">
      <span class="eyebrow eyebrow-light" data-anim="reveal">{c.sectionEyebrow}</span>
      <h2 class="display" data-anim="heading">
        {c.sectionTitleLine1} <em>{c.sectionTitleEmphasis}</em>
      </h2>
      <p class="section-lead" data-anim="reveal">{c.sectionLead}</p>
    </header>

    <div class="contact-shell" data-anim="reveal">
      <div class="contact-grid">
        <div class="contact-info">
          <div class="contact-status">
            <span>Analyse beschikbaar</span>
            <strong>Uw administratie in kaart</strong>
          </div>

          <ul class="contact-list">
            {c.phoneDisplay && (
              <li>
                <span class="ci-label">Telefoon</span>
                <a href={`tel:${phoneHref}`} class="ci-value">{c.phoneDisplay}</a>
              </li>
            )}
            <li>
              <span class="ci-label">E-mail</span>
              <a href={`mailto:${c.email}`} class="ci-value">{c.email}</a>
            </li>
            {c.address && (
              <li>
                <span class="ci-label">Adres</span>
                <span class="ci-value">{c.address}</span>
              </li>
            )}
            {c.workArea && (
              <li>
                <span class="ci-label">Regio</span>
                <span class="ci-value">{c.workArea}</span>
              </li>
            )}
            {c.hours && (
              <li>
                <span class="ci-label">Bereikbaar</span>
                <span class="ci-value">{c.hours}</span>
              </li>
            )}
          </ul>

          <div class="contact-kpis" aria-label="Wat u mag verwachten">
            <span>Antwoord binnen 1 werkdag</span>
            <span>Administratie-audit</span>
            <span>Geen standaardpakket</span>
          </div>

          <div class="contact-socials" aria-label="Sociale media">
            {settings.socials.linkedin && (
              <a href={settings.socials.linkedin} target="_blank" rel="noopener">LinkedIn</a>
            )}
          </div>
        </div>

        <div class="contact-panel" data-anim="reveal" data-delay="0.1">
          <div class="contact-panel-head">
            <span>Start hier</span>
            <strong>Ontdek uw grootste tijdswinst</strong>
          </div>
          <ContactForm />
        </div>
      </div>
    </div>
  </div>
</section>
