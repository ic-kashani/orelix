---
import settings from "../content/settings.json";
import ContactForm from "./ContactForm.astro";
const c = settings.contact;
const phoneHref = c.phone.replace(/\s+/g, "");
---
<section id="contact" class="section contact">
  <div class="container">
    <header class="section-head-split section-head-split--on-dark">
      <div class="section-head-intro">
        <span class="eyebrow eyebrow-light">Contact</span>
        <h2 class="display">Klaar om uw project te <em>starten?</em></h2>
      </div>
      <p class="section-lead section-lead--split section-lead--on-dark">
        Vertel ons over uw project. We bellen u terug binnen 24u - meestal sneller.
      </p>
    </header>

    <div class="contact-grid">
      <div class="contact-info">
        <ul class="contact-list">
          <li>
            <span class="ci-label">Telefoon</span>
            <a href={`tel:${phoneHref}`} class="ci-value">{c.phoneDisplay}</a>
          </li>
          <li>
            <span class="ci-label">E-mail</span>
            <a href={`mailto:${c.email}`} class="ci-value">{c.email}</a>
          </li>
          <li>
            <span class="ci-label">Adres</span>
            <span class="ci-value">{c.address}</span>
          </li>
          <li>
            <span class="ci-label">Werkgebied</span>
            <span class="ci-value">{c.workArea}</span>
          </li>
          <li>
            <span class="ci-label">Werkuren</span>
            <span class="ci-value">{c.hours}</span>
          </li>
        </ul>

        <div class="contact-socials" aria-label="Sociale media">
          {settings.social.instagram && (
            <a href={settings.social.instagram} target="_blank" rel="noopener">
              Instagram
            </a>
          )}
          {settings.social.youtube && (
            <a href={settings.social.youtube} target="_blank" rel="noopener">
              YouTube
            </a>
          )}
          {settings.social.tiktok && (
            <a href={settings.social.tiktok} target="_blank" rel="noopener">
              TikTok
            </a>
          )}
          {settings.social.facebook && (
            <a href={settings.social.facebook} target="_blank" rel="noopener">
              Facebook
            </a>
          )}
        </div>
      </div>

      <ContactForm />
    </div>
  </div>
</section>
