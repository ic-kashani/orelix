---
import settings from "../content/settings.json";
import ContactForm from "./ContactForm.astro";
const c = settings.contact;
const phoneHref = c.phone?.replace(/\s+/g, "") ?? "";
---
<section id="contact" class="section contact">
  <div class="container">
    <header class="section-head">
      <span class="eyebrow eyebrow-light" data-anim="reveal">{c.sectionEyebrow}</span>
      <h2 class="display" data-anim="heading">
        {c.sectionTitleLine1} <em>{c.sectionTitleEmphasis}</em>
      </h2>
      <p class="section-lead" data-anim="reveal">{c.sectionLead}</p>
    </header>

    <div class="contact-shell" data-anim="reveal">
      <div class="contact-grid">
        <div class="contact-info">
          <div class="contact-status">
            <span>Intake online</span>
            <strong>Discovery queue open</strong>
          </div>

          <ul class="contact-list">
            {c.phoneDisplay && (
              <li>
                <span class="ci-label">Phone</span>
                <a href={`tel:${phoneHref}`} class="ci-value">{c.phoneDisplay}</a>
              </li>
            )}
            <li>
              <span class="ci-label">Email</span>
              <a href={`mailto:${c.email}`} class="ci-value">{c.email}</a>
            </li>
            {c.address && (
              <li>
                <span class="ci-label">Address</span>
                <span class="ci-value">{c.address}</span>
              </li>
            )}
            {c.workArea && (
              <li>
                <span class="ci-label">Coverage</span>
                <span class="ci-value">{c.workArea}</span>
              </li>
            )}
            {c.hours && (
              <li>
                <span class="ci-label">Hours</span>
                <span class="ci-value">{c.hours}</span>
              </li>
            )}
          </ul>

          <div class="contact-kpis" aria-label="Discovery process highlights">
            <span>24h reply window</span>
            <span>Workflow audit</span>
            <span>No generic demos</span>
          </div>

          <div class="contact-socials" aria-label="Social media">
            {settings.social.linkedin && (
              <a href={settings.social.linkedin} target="_blank" rel="noopener">LinkedIn</a>
            )}
          </div>
        </div>

        <div class="contact-panel" data-anim="reveal" data-delay="0.1">
          <div class="contact-panel-head">
            <span>Start here</span>
            <strong>Map your first AI employee</strong>
          </div>
          <ContactForm />
        </div>
      </div>
    </div>
  </div>
</section>
