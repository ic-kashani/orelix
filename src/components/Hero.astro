---
import settings from "../content/settings.json";
const h = settings.hero;
const heroImage = h.image;

type Stat = { value: string; label: string };
const stats: Stat[] = h.stats;
const parseStat = (value: string) => {
  const m = value.match(/^(\d+)(\D*)$/);
  return m ? { num: m[1], suffix: m[2] } : null;
};
---
<section class="hero" data-hero>
  <div
    class="hero-canvas"
    data-hero-canvas
    data-hero-src={heroImage}
    style={`--hero-img: url('${heroImage}')`}
    aria-hidden="true"
  ></div>
  <div class="hero-scrim" aria-hidden="true"></div>

  <div class="container hero-inner">
    <span class="eyebrow eyebrow-light hero-eyebrow" data-hero-stagger>
      <span class="hero-eyebrow-full">{h.eyebrow}</span>
      <span class="hero-eyebrow-short">{h.eyebrowShort}</span>
    </span>
    <h1 class="hero-title display" data-hero-title>
      {h.titleLine1}
    </h1>
    <p class="hero-subtitle" data-hero-stagger>{h.titleLine2}</p>
    <p class="hero-lead" data-hero-stagger>{h.lead}</p>
    {h.lead2 && <p class="hero-lead hero-lead--secondary" data-hero-stagger>{h.lead2}</p>}

    <div class="hero-actions" data-hero-stagger>
      <a href="/#contact" class="btn btn-primary btn-lg">{h.ctaPrimary}</a>
      <a href={h.ctaSecondaryHref} class="btn btn-ghost btn-lg">{h.ctaSecondary}</a>
    </div>

    <div class="hero-stats" data-hero-stagger aria-label="Key highlights">
      {stats.map((s) => {
        const p = parseStat(s.value);
        return (
          <div class="hero-stat">
            {p ? (
              <strong data-count={p.num} data-count-suffix={p.suffix}>0{p.suffix}</strong>
            ) : (
              <strong>{s.value}</strong>
            )}
            <span>{s.label}</span>
          </div>
        );
      })}
    </div>
  </div>

  <span class="hero-cue" data-hero-cue>Scroll</span>
</section>
