---
import { getCollection } from "astro:content";
import settings from "../content/settings.json";
const items = (await getCollection("projects")).sort(
  (a, b) => a.data.order - b.data.order,
);

// Visual rhythm for the asymmetric grid. Honour an explicit gridLayout when set,
// otherwise cycle a pleasing pattern so the masonry never feels mechanical.
const pattern = ["large", "small", "tall", "wide", "small", "small", "tall", "small", "wide", "small", "large", "small"];
const layoutClass = (i: number, explicit?: string) => {
  const layout = explicit || pattern[i % pattern.length];
  return layout === "small" ? "" : `is-${layout}`;
};
---
<section id="realisaties" class="section portfolio">
  <div class="container">
    <div class="gallery">
      {items.map((item, i) => (
        <figure
          class={`gallery-item ${layoutClass(i, item.data.gridLayout)}`}
          data-lightbox
          data-lb-src={item.data.image}
          data-lb-cat={item.data.category}
          data-lb-loc={item.data.location}
          data-cursor="Bekijk"
        >
          <img src={item.data.image} alt={item.data.alt} loading="lazy" decoding="async" />
          <figcaption>
            <span class="cap-cat">{item.data.category}</span>
            <span class="cap-loc">{item.data.location}</span>
          </figcaption>
        </figure>
      ))}
    </div>

    <div class="portfolio-cta">
      <p>Meer realisaties op onze sociale kanalen</p>
      <div class="social-row">
        {settings.social.instagram && (
          <a href={settings.social.instagram} target="_blank" rel="noopener" class="social-pill">
            <span class="social-icon-mark" aria-hidden="true">IG</span>
            <span>Instagram</span>
          </a>
        )}
        {settings.social.youtube && (
          <a href={settings.social.youtube} target="_blank" rel="noopener" class="social-pill">
            <span class="social-icon-mark" aria-hidden="true">YT</span>
            <span>YouTube</span>
          </a>
        )}
        {settings.social.tiktok && (
          <a href={settings.social.tiktok} target="_blank" rel="noopener" class="social-pill">
            <span class="social-icon-mark" aria-hidden="true">TT</span>
            <span>TikTok</span>
          </a>
        )}
        {settings.social.facebook && (
          <a href={settings.social.facebook} target="_blank" rel="noopener" class="social-pill">
            <span class="social-icon-mark" aria-hidden="true">f</span>
            <span>Facebook</span>
          </a>
        )}
      </div>
    </div>
  </div>
</section>
