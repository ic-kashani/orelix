---
interface Props {
  eyebrow: string;
  title: string;
  lead: string;
  points: string[];
  problemTitle: string;
  problem: string[];
  steps: { title: string; body: string }[];
  situations: { title: string; body: string }[];
  faq: { question: string; answer: string }[];
  related: { href: string; label: string }[];
}

const { eyebrow, title, lead, points, problemTitle, problem, steps, situations, faq, related } = Astro.props;
---

<main id="main" class="solution-page">
  <section class="solution-hero">
    <div class="container solution-hero-grid">
      <div>
        <span class="eyebrow eyebrow-light">{eyebrow}</span>
        <h1 class="display">{title}</h1>
        <p class="section-lead">{lead}</p>
      </div>
      <ul class="solution-points" aria-label="Wat dit oplevert">
        {points.map((point) => <li>{point}</li>)}
      </ul>
    </div>
  </section>

  <section class="solution-section">
    <div class="container">
      <div class="solution-copy">
        <span class="eyebrow">Praktisch bekeken</span>
        <h2 class="display">{problemTitle}</h2>
        {problem.map((paragraph) => <p>{paragraph}</p>)}
      </div>

      <div class="solution-steps">
        {steps.map((step, index) => (
          <article class="solution-step">
            <span class="solution-step-number">0{index + 1}</span>
            <h2>{step.title}</h2>
            <p>{step.body}</p>
          </article>
        ))}
      </div>

      <div class="solution-links" aria-label="Lees ook">
        {related.map((link) => <a href={link.href}>{link.label} &rarr;</a>)}
      </div>
    </div>
  </section>

  <section class="solution-section solution-section--soft">
    <div class="container">
      <div class="solution-copy">
        <span class="eyebrow">Herkenbaar in de praktijk</span>
        <h2 class="display">Waar automatisatie concreet helpt.</h2>
        <p>We beginnen niet bij software, maar bij situaties die uw medewerkers en klanten vandaag echt ervaren.</p>
      </div>
      <div class="solution-situations">
        {situations.map((situation) => (
          <article class="solution-situation">
            <h2>{situation.title}</h2>
            <p>{situation.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="solution-section solution-faq">
    <div class="container solution-faq-grid">
      <div class="solution-copy">
        <span class="eyebrow">Veelgestelde vragen</span>
        <h2 class="display">Duidelijk voor u begint.</h2>
        <p>Elke werking is anders. Deze antwoorden geven u alvast een realistisch beeld van hoe Orelix te werk gaat.</p>
      </div>
      <div class="solution-faq-list">
        {faq.map((item) => (
          <details>
            <summary>{item.question}</summary>
            <p>{item.answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="cta-band">
    <div class="container cta-band-inner">
      <div>
        <span class="eyebrow eyebrow-light">Gratis analyse</span>
        <h2 class="display">Ontdek waar uw werking sneller kan.</h2>
        <p class="section-lead">We bekijken samen welke repetitieve taken tijd kosten of ervoor zorgen dat aanvragen blijven liggen.</p>
      </div>
      <a href="/#contact" class="btn btn-primary btn-lg">Plan een gratis analyse</a>
    </div>
  </section>
</main>
