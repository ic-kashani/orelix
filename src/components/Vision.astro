---
import settings from "../content/settings.json";

interface Props {
  asPage?: boolean;
}

const { asPage = false } = Astro.props;
const v = settings.vision;
const Tag = asPage ? "h1" : "h2";
const manifestoLead = v.manifesto[0];
const manifestoRest = v.manifesto.slice(1);
---
<section id="vision" class={`section vision${asPage ? " vision--page" : ""}`}>
  <div class="container">
    <div class="vision-inner">
      <div class="vision-hero">
        <div class="vision-copy">
          <span class="eyebrow eyebrow-light" data-anim="reveal">{v.eyebrow}</span>
          <Tag class="display vision-title" data-anim="heading">
            {v.titlePrefix}{" "}<em class="vision-highlight">{v.titleHighlight}</em>
          </Tag>

          {v.intro && (
            <p class="vision-intro" data-anim="reveal">{v.intro}</p>
          )}
        </div>

        <div class="vision-system" data-anim="reveal" aria-hidden="true">
          <div class="vision-orbit vision-orbit--outer"></div>
          <div class="vision-orbit vision-orbit--inner"></div>
          <div class="vision-core">
            <span>Rust</span>
            <strong>Voor uw team</strong>
          </div>
          <span class="vision-signal vision-signal--one">Overzicht</span>
          <span class="vision-signal vision-signal--two">Opvolging</span>
          <span class="vision-signal vision-signal--three">Tijdswinst</span>
        </div>
      </div>

      {manifestoLead && (
        <div class="vision-manifesto" data-anim="reveal" aria-label="Onze visie">
          <p class="vision-line vision-line--lead">{manifestoLead}</p>
          <div class="vision-manifesto-stack">
            {manifestoRest.map((line) => (
              <p class="vision-line">{line}</p>
            ))}
          </div>
        </div>
      )}

      {asPage && v.sections && (
        <div class="vision-sections" data-anim="reveal">
          {v.sections.map((section, index) => (
            <article class="vision-block">
              <span class="vision-block-index">0{index + 1}</span>
              <h2 class="vision-block-title">{section.title}</h2>
              <p class="vision-block-body">{section.body}</p>
            </article>
          ))}
        </div>
      )}

      {asPage && v.principles && (
        <div class="vision-principles" data-anim="reveal">
          <h2 class="vision-principles-label">Waar we voor staan</h2>
          <ul>
            {v.principles.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </div>
      )}

      <div class="vision-close-panel" data-anim="reveal">
        <p class="vision-closing">{v.closing}</p>
        {v.closingLine && (
          <p class="vision-closing-line">{v.closingLine}</p>
        )}

        {asPage && (
          <a href="/#contact" class="btn btn-primary btn-lg vision-cta">
            Plan een gratis analyse
          </a>
        )}
      </div>
    </div>
  </div>
</section>
