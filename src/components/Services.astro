---
import { getCollection } from "astro:content";
import settings from "../content/settings.json";
const s = settings.services;
const items = (await getCollection("services")).sort(
  (a, b) => a.data.order - b.data.order,
);
---
<section id="services" class="services" data-services>
  <div class="services-track" data-services-track>
    <div class="panel service-intro">
      <span class="eyebrow">{s.eyebrow}</span>
      <h2 class="display">{s.titleLine1} <em>{s.titleEmphasis}</em></h2>
      <p>{s.lead}</p>
      <span class="services-hint">Bekijk oplossingen &rarr;</span>
    </div>

    {items.map(async (item, i) => {
      const { Content } = await item.render();
      return (
        <article class="panel service-card" data-service-card>
          <div class="service-card-media">
            <img
              src={item.data.image}
              alt={item.data.imageAlt}
              class="service-card-img"
              loading="lazy"
              decoding="async"
              width="800"
              height="1000"
            />
          </div>
          <div class="service-card-content">
            <span class="service-index">{String(i + 1).padStart(2, "0")}</span>
            <h3>{item.data.title}</h3>
            <div class="service-body"><Content /></div>
          </div>
        </article>
      );
    })}

    <div class="panel service-outro">
      <span class="eyebrow">{s.outroEyebrow}</span>
      <h3>{s.outroTitle}</h3>
      <p>{s.outroLead}</p>
      <a href="/#contact" class="btn btn-primary btn-lg">{s.outroCta}</a>
    </div>
  </div>

  <div class="services-progress-track" aria-hidden="true">
    <span class="services-progress" data-services-progress></span>
  </div>
</section>
