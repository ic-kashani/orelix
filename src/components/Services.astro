---
import { getCollection } from "astro:content";
const items = (await getCollection("services")).sort(
  (a, b) => a.data.order - b.data.order,
);
---
<section id="diensten" class="section services">
  <div class="container">
    <header class="section-head-split">
      <div class="section-head-intro">
        <span class="eyebrow">Diensten</span>
        <h2 class="display">Elk project, met dezelfde precisie.</h2>
      </div>
      <p class="section-lead section-lead--split">
        Van tegelwerk en badkamers tot volledige renovatie en vloerafwerking -
        laminaat, parket en meer. Strak, tijdloos werk dat decennia meegaat.
      </p>
    </header>

    <div class="services-grid">
      {items.map(async (item) => {
        const { Content } = await item.render();
        return (
          <article class="service-card">
            <div class="service-card-visual">
              <img
                src={item.data.image}
                alt={item.data.imageAlt}
                class="service-card-img"
                loading="lazy"
                decoding="async"
                width="800"
                height="520"
              />
              <div class="service-card-scrim" aria-hidden="true" />
            </div>
            <div class="service-card-panel">
              <h3>{item.data.title}</h3>
              <div class="service-body">
                <Content />
              </div>
            </div>
          </article>
        );
      })}
    </div>
  </div>
</section>
