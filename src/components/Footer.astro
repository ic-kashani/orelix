---
import settings from "../content/settings.json";

const c = settings.contact;
const phoneHref = c.phone?.replace(/\s+/g, "") ?? "";
const nav = [
  { href: "/vision", label: "Onze aanpak" },
  { href: "/oplossingen", label: "Oplossingen" },
  { href: "/how-we-work", label: "Werkwijze" },
  { href: "/#industries", label: "Sectoren" },
  { href: "/#contact", label: "Contact" },
];
const hasLogo = Boolean(settings.business.logo);
const logoTag = settings.business.logoTag;
---
<footer class="site-footer">
  <div class="footer-wordmark" aria-hidden="true">ORELIX</div>
  <div class="container footer-grid">
    <div class="footer-brand">
      <a href="/" class={`logo${hasLogo ? " logo--lockup" : ""}`} aria-label={settings.business.name}>
        {hasLogo ? (
          <img
            src={settings.business.logo}
            alt={settings.business.logoAlt}
            class="logo-image"
            width="1024"
            height="682"
          />
        ) : (
          <>
            <span class="logo-mark" aria-hidden="true">{settings.business.shortName.charAt(0)}</span>
            <span class="logo-wordmark">
              <span class="logo-name">{settings.business.shortName}</span>
              <span class="logo-tag">{logoTag}</span>
            </span>
          </>
        )}
      </a>
      <p>
        {settings.business.description}<br />
        <em>{settings.business.tagline}</em>
      </p>
    </div>

    <div class="footer-col">
      <h4>Navigatie</h4>
      <ul>
        {nav.map((n) => <li><a href={n.href}>{n.label}</a></li>)}
      </ul>
    </div>

    <div class="footer-col">
      <h4>Waarmee we helpen</h4>
      <ul>
        <li><a href="/offerte-opvolging-automatiseren">Offertes opvolgen</a></li>
        <li><a href="/e-mails-en-administratie-automatiseren">E-mails en administratie</a></li>
        <li><a href="/automatisatie-installatiebedrijven">Voor installatiebedrijven</a></li>
      </ul>
    </div>

    <div class="footer-col">
      <h4>Volg ons</h4>
      <ul>
        {settings.socials.linkedin && (
          <li><a href={settings.socials.linkedin} target="_blank" rel="noopener">LinkedIn</a></li>
        )}
      </ul>
    </div>

    <div class="footer-col">
      <h4>Contact</h4>
      <ul>
        {c.phoneDisplay && <li><a href={`tel:${phoneHref}`}>{c.phoneDisplay}</a></li>}
        <li><a href={`mailto:${c.email}`}>{c.email}</a></li>
      </ul>
    </div>
  </div>

  <div class="container footer-bottom">
    <span>&copy; <span id="year">2026</span> {settings.business.name} - {settings.business.tagline}</span>
  </div>
</footer>
