---
import "../styles/global.css";
import settings from "../content/settings.json";
import Preloader from "../components/Preloader.astro";

interface Props {
  title?: string;
  description?: string;
  structuredData?: Record<string, unknown>;
}

const { title, description, structuredData } = Astro.props;
const pageTitle = title
  ? title.endsWith(`| ${settings.business.name}`)
    ? title
    : `${title} | ${settings.business.name}`
  : `${settings.business.name} - ${settings.business.tagline}`;
const pageDescription = description ?? settings.business.description;
const t = settings.theme;
const siteUrl = (
  import.meta.env.PUBLIC_SITE_URL?.trim() || settings.site.url
).replace(/\/$/, "");
const canonicalUrl = new URL(Astro.url.pathname, `${siteUrl}/`).toString();
const socialImage = new URL(settings.seo.ogImage, `${siteUrl}/`).toString();
const isHome = Astro.url.pathname === "/";
const organizationSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": `${siteUrl}/#organization`,
      name: settings.business.name,
      url: siteUrl,
      logo: socialImage,
      email: settings.contact.email,
      telephone: settings.contact.phone,
      sameAs: Object.values(settings.socials).filter(Boolean),
      areaServed: {
        "@type": "Country",
        name: "Belgium",
      },
    },
    {
      "@type": "WebSite",
      "@id": `${siteUrl}/#website`,
      name: settings.business.name,
      url: siteUrl,
      inLanguage: settings.site.lang,
      publisher: { "@id": `${siteUrl}/#organization` },
    },
  ],
};
---
<!DOCTYPE html>
<html lang={settings.site.lang}>
  <head>
    <script is:inline>
      document.documentElement.classList.add("js");
    </script>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, viewport-fit=cover"
    />
    <meta name="theme-color" content={t.colorInk} />
    <meta name="description" content={pageDescription} />
    <meta name="format-detection" content="telephone=yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content={settings.business.name} />

    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={settings.site.ogLocale} />
    <meta property="og:site_name" content={settings.business.name} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:image:alt" content={settings.business.logoAlt} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={socialImage} />

    <title>{pageTitle}</title>
    <link rel="canonical" href={canonicalUrl} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
    {structuredData && (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)} />
    )}
    {isHome && (
      <link rel="preload" as="image" href={settings.hero.image} type="image/webp" fetchpriority="high" />
    )}

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Inter:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />

    <link rel="icon" type="image/png" href="/uploads/logo.png" />
    <link rel="apple-touch-icon" href="/uploads/logo.png" />

    <style is:global define:vars={{
      colorBg: t.colorBg,
      colorBgAlt: t.colorBgAlt,
      colorInk: t.colorInk,
      colorInkSoft: t.colorInkSoft,
      colorInkMuted: t.colorInkMuted,
      colorAccent: t.colorAccent,
      colorAccentDeep: t.colorAccentDeep,
      colorDark: t.colorDark,
      fontDisplay: `"${t.fontDisplay}", "Times New Roman", serif`,
      fontBody: `"${t.fontBody}", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif`,
    }}>
      :root {
        --color-bg: var(--colorBg);
        --color-bg-alt: var(--colorBgAlt);
        --color-ink: var(--colorInk);
        --color-ink-soft: var(--colorInkSoft);
        --color-ink-muted: var(--colorInkMuted);
        --color-accent: var(--colorAccent);
        --color-accent-deep: var(--colorAccentDeep);
        --color-dark: var(--colorDark);
        --font-display: var(--fontDisplay);
        --font-body: var(--fontBody);
      }
    </style>
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <Preloader />
    <script is:inline>
      // Bundle-independent failsafe: if the motion bundle ever fails to load or
      // run, never leave the intro curtain covering the page.
      (function () {
        var clear = function () {
          document.body.classList.remove("is-loading");
          var p = document.querySelector("[data-preloader]");
          if (p && p.parentNode && !p.dataset.done) p.style.display = "none";
        };
        window.setTimeout(clear, 5000);
        window.addEventListener("error", function (e) {
          if (e && e.filename && e.filename.indexOf("astro") === -1) clear();
        });
      })();
    </script>
    <slot />
    <script>
      import { initApp } from "../scripts/app";
      initApp();
    </script>
  </body>
</html>
